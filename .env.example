# .env.example — Sentinel
# Copy to .env and fill in your values.
# NEVER commit .env to git. It is in .gitignore.

# ── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Cloudflare ─────────────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CF_D1_DATABASE_ID=              # from: wrangler d1 list
CF_R2_BUCKET=sentinel-cassettes
CF_VECTORIZE_INDEX=sentinel-embeddings

# ── Atlassian ──────────────────────────────────────────────────────────────
ATLASSIAN_SITE=https://your-site.atlassian.net
ATLASSIAN_EMAIL=your@email.com
ATLASSIAN_API_TOKEN=            # from: id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_JSM_SERVICE_DESK_ID=  # from: GET /rest/servicedeskapi/servicedesk
ATLASSIAN_JIRA_PROJECT_KEY=SENT

# ── Langfuse (self-hosted on Azure VM) ─────────────────────────────────────
LANGFUSE_HOST=https://langfuse.yourteamdomain.com
LANGFUSE_PUBLIC_KEY=pk-lf-
LANGFUSE_SECRET_KEY=sk-lf-

# ── OTel (required for gen_ai.* spans) ─────────────────────────────────────
OTEL_SEMCONV_STABILITY_OPT_IN=gen_ai_latest_experimental

# ── Azure VM ────────────────────────────────────────────────────────────────
AZURE_VM_HOST=         # public IP or DNS of your Azure VM
AZURE_VM_USER=sentinel

# ── Forge Remote Backend ────────────────────────────────────────────────────
FORGE_REMOTE_URL=https://remote.yourteamdomain.com
FORGE_REMOTE_SECRET=   # random 32+ char string, must match on both client and server

# ── Audit ───────────────────────────────────────────────────────────────────
AUDIT_HMAC_KEY=        # random 32+ char string for HMAC-signing audit records
                       # Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"

# ── App Config ──────────────────────────────────────────────────────────────
FLIGHT_MODE=record     # "record" | "replay" | "passthrough"
EVAL_CONFIDENCE_THRESHOLD=0.70
VECTOR_SIMILARITY_THRESHOLD=0.75
LOG_LEVEL=INFO

# ── Dashboard ───────────────────────────────────────────────────────────────
# (put in packages/dashboard/.env.local for Next.js)
# NEXT_PUBLIC_EVAL_API_URL=http://localhost:8000
# NEXT_PUBLIC_FLIGHT_RECORDER_URL=http://localhost:8001
