# .env.example — Sentinel
# Copy to .env and fill in your values.  NEVER commit .env (it is in .gitignore).
# This template mirrors the env vars the code actually reads — see root CLAUDE.md §3.

# ── Cloudflare Workers AI (replaces Anthropic — no Anthropic key needed) ─────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CF_AI_MODEL_MAIN=@cf/meta/llama-3.3-70b-instruct-fp8-fast   # RCA + LLM judge
CF_AI_MODEL_SAFETY=@cf/meta/llama-guard-3-8b                # safety pre-filter
CF_AI_MODEL_EMBED=@cf/baai/bge-base-en-v1.5                 # 768-dim embeddings

# ── Cloudflare D1 + Vectorize ────────────────────────────────────────────────
CF_D1_DATABASE_ID=              # from: wrangler d1 list
CF_VECTORIZE_INDEX=sentinel-embeddings
# (R2 + Queues were skipped — see root CLAUDE.md §9. Blobs use MinIO, below.)

# ── Blob Storage (MinIO — S3-compatible, NOT Cloudflare R2) ──────────────────
BLOB_STORAGE_ENDPOINT=http://localhost:9090
BLOB_STORAGE_BUCKET=sentinel-cassettes
BLOB_STORAGE_ACCESS_KEY=minio
BLOB_STORAGE_SECRET_KEY=        # from /srv/sentinel/.env on the VM
BLOB_STORAGE_USE_SSL=false

# ── xqdrant (vector search — internal only, replaces Vectorize for search) ───
XQDRANT_URL=http://localhost:6333
XQDRANT_INCIDENTS_COLLECTION=incidents
XQDRANT_RUNBOOKS_COLLECTION=runbooks

# ── Atlassian ────────────────────────────────────────────────────────────────
ATLASSIAN_SITE=https://your-site.atlassian.net
ATLASSIAN_EMAIL=your@email.com
ATLASSIAN_API_TOKEN=            # from: id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_JSM_SERVICE_DESK_ID=1 # from: GET /rest/servicedeskapi/servicedesk
ATLASSIAN_JIRA_PROJECT_KEY=AO   # AO is the JSM project (Incident type id 10013)
ATLASSIAN_DUPLICATE_LINK_TYPE=Duplicate # Jira issue-link type for auto-linked duplicates (must exist on the site)

# ── Langfuse (self-hosted on Azure VM) ─────────────────────────────────────
LANGFUSE_HOST=https://langfuse.yourteamdomain.com
# Internal URL the SDK delivers traces to (bypasses the public Cloudflare bot
# challenge). On the VM this is http://127.0.0.1:3000; falls back to LANGFUSE_HOST.
LANGFUSE_HOST_INTERNAL=http://127.0.0.1:3000
LANGFUSE_PUBLIC_KEY=pk-lf-
LANGFUSE_SECRET_KEY=sk-lf-

# ── Flight Recorder (UC2) ────────────────────────────────────────────────────
FLIGHT_MODE=record              # "record" | "replay" | "passthrough"
FLIGHT_RECORDER_URL=http://localhost:8001   # eval-engine loads traces from here (prod: https://flight.ahmedxsaad.me)
AUDIT_HMAC_KEY=                 # random 32+ char secret for HMAC-signing audit records
                                # Generate: python3 -c "import secrets; print(secrets.token_hex(32))"

# ── Eval Engine (UC1) ────────────────────────────────────────────────────────
EVAL_CONFIDENCE_THRESHOLD=0.70
VECTOR_SIMILARITY_THRESHOLD=0.75
EVAL_ENGINE_URL=http://localhost:8000   # atlassian-remote POSTs /evaluate here (internal VM-to-VM)

# ── OTel (required for gen_ai.* spans) ─────────────────────────────────────
OTEL_SEMCONV_STABILITY_OPT_IN=gen_ai_latest_experimental

# ── Azure VM ────────────────────────────────────────────────────────────────
AZURE_VM_HOST=                  # public IP or DNS of your Azure VM
AZURE_VM_USER=sentinel

# ── Forge Remote Backend (UC3) ──────────────────────────────────────────────
FORGE_REMOTE_URL=https://remote.yourteamdomain.com
FORGE_REMOTE_SECRET=            # random 32+ char string, must match on client and server

# ── Misc ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Dashboard ───────────────────────────────────────────────────────────────
# (put in packages/dashboard/.env.local for Next.js)
# NEXT_PUBLIC_EVAL_API_URL=http://localhost:8000
# NEXT_PUBLIC_FLIGHT_RECORDER_URL=http://localhost:8001
